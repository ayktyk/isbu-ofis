NODE_ENV=development
PORT=3001

# Neon
# Runtime icin tek sunucu kullanacaksan direct URL ile baslayabilirsin.
# Serverless/pooling ihtiyacinda pooled URL kullan.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Drizzle migration icin direct URL kullanman daha guvenli.
DATABASE_URL_MIGRATION=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Frontend origins
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=
# Vercel preview domain'lerini toplu acmak istersen regex kullan.
# Ornek: ^https://.*\.vercel\.app$
CORS_ORIGIN_REGEX=

# Auth / cookies
COOKIE_SECRET=change-this-cookie-secret
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
ENABLE_SCHEDULED_JOBS=false

JWT_SECRET=change-this-jwt-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Google Calendar reminder integration
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_REMINDER_MINUTES=4320
GOOGLE_CALENDAR_TIMEZONE=Europe/Istanbul

ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=
ADMIN_BAR_NUMBER=
ADMIN_PHONE=

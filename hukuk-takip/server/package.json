{
  "name": "@hukuk-takip/server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "node --env-file=../.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../.env ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "node --env-file=../.env ./node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:bootstrap-admin": "node --env-file=../.env --import=tsx ./src/db/bootstrapAdmin.ts"
  },
  "dependencies": {
    "@hukuk-takip/shared": "*",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.2",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
